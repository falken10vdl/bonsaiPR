# BonsaiPR collaborator test configuration
# Copy to .env on your machine and replace all placeholder values.
#
# This template is for independent testing on a collaborator machine.
# Please ask for permission, or test in your own forks.

# GitHub token with repo write permissions for the target repos
GITHUB_TOKEN=ghp_replace_with_your_token

# Release target repository (shared production target)
GITHUB_OWNER=falken10vdl
GITHUB_REPO=bonsaiPR

# Fork repository used for merged build branches
FORK_OWNER=falken10vdl
FORK_REPO=IfcOpenShell

# Upstream source repository and base branch
SOURCE_REPO_OWNER=IfcOpenShell
SOURCE_REPO_NAME=IfcOpenShell
SOURCE_BASE_BRANCH=v0.8.0

# Local paths on YOUR machine (ex. username=theoryshaw)
BASE_CLONE_DIR=/home/theoryshaw/bonsaiPRDevel/IfcOpenShell
BUILD_BASE_DIR=/home/theoryshaw/bonsaiPRDevel/bonsaiPR-build
REPORT_PATH=/home/theoryshaw/bonsaiPRDevel/reports
WORKING_DIR=/home/theoryshaw/bonsaiPRDevel/MergingPR

# Optional filtering
USERNAMES=""          # empty = all PR authors
EXCLUDED=""          # comma-separated PR numbers to exclude

# Optional overrides for independent sandbox testing
# GITHUB_OWNER=your-github-user
# GITHUB_REPO=bonsaiPR
# FORK_OWNER=your-github-user
