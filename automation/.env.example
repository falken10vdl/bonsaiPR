# BonsaiPR Automation Configuration
# Copy this file to .env and update with your values

GITHUB_TOKEN=your_github_token_here

# Release target repository (where GitHub releases and index updates are published)
GITHUB_OWNER=falken10vdl
GITHUB_REPO=bonsaiPR

# Fork repository for merged build branches
FORK_OWNER=falken10vdl
FORK_REPO=IfcOpenShell

# Upstream source repository and base branch
SOURCE_REPO_OWNER=IfcOpenShell
SOURCE_REPO_NAME=IfcOpenShell
SOURCE_BASE_BRANCH=v0.8.0

BASE_CLONE_DIR=your_base_clone_directory_here
WORKING_DIR=your_working_directory_here
REPORT_PATH=your_report_path_here
USERNAMES=""  # empty means all PR authors
EXCLUDED=5452